import cv2
from ultralytics import YOLO

# Load a pre-trained YOLOv8n model
# Make sure the 'yolov8n.pt' file is in the same directory as this script,
# or provide the full path to the model file.
# The model will download automatically if not found.
model = YOLO('yolov8n.pt')

print(f"YOLOv8 model loaded successfully. Model device: {model.device}")

# Initialize webcam capture (0 is usually the default webcam)
# If you have multiple cameras or an external one, you might need to try 1, 2, etc.
cap = cv2.VideoCapture(0)

# Check if webcam opened successfully
if not cap.isOpened():
    print("Error: Could not open video stream from webcam.")
    print("Please ensure your webcam is connected and not in use by another application.")
    exit()

print("Webcam opened successfully. Press 'q' to quit.")

while True:
    # Read a frame from the webcam
    ret, frame = cap.read()

    if not ret:
        print("Error: Failed to grab frame.")
        break

    # Perform detection on the frame
    # classes=[0] filters for 'person' class
    # verbose=False to suppress output for each frame in the console
    results = model(frame, classes=[0], verbose=False)

    # Get the annotated frame (with bounding boxes and labels)
    # The .plot() method returns a numpy array which can be displayed by OpenCV
    annotated_frame = results[0].plot()

    # Display the annotated frame
    cv2.imshow('YOLOv8 Real-time Person Detection', annotated_frame)

    # Break the loop if 'q' is pressed
    if cv2.waitKey(1) & 0xFF == ord('q'):
        break

# Release the webcam and destroy all OpenCV windows
cap.release()
cv2.destroyAllWindows()
print("Detection stopped. Webcam released.")
