{
  "script_info": {
    "language": "python",
    "purpose": "Real-time person detection using YOLOv8 and OpenCV via webcam",
    "dependencies": [
      "cv2",
      "ultralytics"
    ],
    "model_used": "yolov8n.pt"
  },
  "code": "import cv2\nfrom ultralytics import YOLO\n\n# Load a pre-trained YOLOv8n model\n# Make sure the 'yolov8n.pt' file is in the same directory as this script,\n# or provide the full path to the model file.\n# The model will download automatically if not found.\nmodel = YOLO('yolov8n.pt')\n\nprint(f\"YOLOv8 model loaded successfully. Model device: {model.device}\")\n\n# Initialize webcam capture (0 is usually the default webcam)\n# If you have multiple cameras or an external one, you might need to try 1, 2, etc.\ncap = cv2.VideoCapture(0)\n\n# Check if webcam opened successfully\nif not cap.isOpened():\n    print(\"Error: Could not open video stream from webcam.\")\n    print(\"Please ensure your webcam is connected and not in use by another application.\")\n    exit()\n\nprint(\"Webcam opened successfully. Press 'q' to quit.\")\n\nwhile True:\n    # Read a frame from the webcam\n    ret, frame = cap.read()\n\n    if not ret:\n        print(\"Error: Failed to grab frame.\")\n        break\n\n    # Perform detection on the frame\n    # classes=[0] filters for 'person' class\n    # verbose=False to suppress output for each frame in the console\n    results = model(frame, classes=[0], verbose=False)\n\n    # Get the annotated frame (with bounding boxes and labels)\n    # The .plot() method returns a numpy array which can be displayed by OpenCV\n    annotated_frame = results[0].plot()\n\n    # Display the annotated frame\n    cv2.imshow('YOLOv8 Real-time Person Detection', annotated_frame)\n\n    # Break the loop if 'q' is pressed\n    if cv2.waitKey(1) & 0xFF == ord('q'):\n        break\n\n# Release the webcam and destroy all OpenCV windows\ncap.release()\ncv2.destroyAllWindows()\nprint(\"Detection stopped. Webcam released.\")"
}
